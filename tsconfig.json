{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleDetection": "legacy",
    "lib": ["DOM", "ES2017"],
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "noEmitOnError": true,
    "removeComments": false,
    "newLine": "lf",
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
